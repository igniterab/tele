{
  "name": "tele",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web",
    "packages/widget"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @tele/api",
    "dev:worker": "npm run dev:worker -w @tele/api",
    "dev:web": "npm run dev -w @tele/web",
    "dev:widget": "npm run dev -w @tele/widget",
    "build": "npm run build -w @tele/shared && npm run build -w @tele/api && npm run build -w @tele/web && npm run build -w @tele/widget",
    "prisma:generate": "npm run prisma:generate -w @tele/api",
    "prisma:migrate": "npm run prisma:migrate -w @tele/api",
    "seed": "npm run seed -w @tele/api"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "esbuild@0.28.1": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@5.22.0": true,
    "fsevents@2.3.3": true,
    "esbuild@0.21.5": true
  }
}
