NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://tele:tele@localhost:5432/tele
REDIS_URL=redis://localhost:6379
SESSION_JWT_SECRET=change-me-session-secret-change-me
VISITOR_JWT_SECRET=change-me-visitor-secret-change-me
WEB_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
EMAIL_DOMAIN=tele.local
SMTP_HOST=localhost
SMTP_PORT=1025
# AI summarization providers, in priority order: if OLLAMA_BASE_URL is set it's
# used; else ANTHROPIC_API_KEY if set; else stub/no-op (no external calls).
# Local open-source model via Ollama (https://ollama.com) — no key needed.
# Apps outside Docker: point at localhost. Inside Docker the compose file uses
# http://host.docker.internal:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
KB_CNAME_TARGET=kb.tele.local
# Dev/demo only — never set true in production. See docs/CUSTOM_DOMAINS.md.
DOMAIN_VERIFICATION_DEV_BYPASS=false
