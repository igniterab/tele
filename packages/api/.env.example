NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://tele:tele@localhost:5432/tele
REDIS_URL=redis://localhost:6379
SESSION_JWT_SECRET=change-me-session-secret-change-me
VISITOR_JWT_SECRET=change-me-visitor-secret-change-me
WEB_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
EMAIL_DOMAIN=tele.local
SMTP_HOST=localhost
SMTP_PORT=1025
# Leave unset to run AI summarization in stub/fallback mode (no external calls).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
KB_CNAME_TARGET=kb.tele.local
# Dev/demo only — never set true in production. See docs/CUSTOM_DOMAINS.md.
DOMAIN_VERIFICATION_DEV_BYPASS=false
